# BackRow Environment Variables
# Copy this file to .env.local and fill in your values.

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
# Project: https://supabase.com/dashboard/project/nxpeptgrhbveqphwwowj
# "publishable key" is the 2026 rename of the legacy anon JWT. Both are safe
# to ship to browsers. We export both so existing `createClient({ anonKey })`
# call sites keep working while we migrate to the new publishable flow.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi... # legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role — bypasses RLS. Server-only. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Direct Postgres connection (scripts, migrations, pg_dump). Note: the password
# character class may need URL-encoding.
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ----------------------------------------------------------------------------
# TMDB (movie data)
# ----------------------------------------------------------------------------
TMDB_API_KEY=your_tmdb_api_key_here

# ----------------------------------------------------------------------------
# Resend (transactional email)
# ----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxx
# Optional — overrides the default "BackRow <noreply@backrow.tv>" sender.
RESEND_FROM_EMAIL=
# Optional — recipient for contact-form submissions.
CONTACT_NOTIFY_EMAIL=

# ----------------------------------------------------------------------------
# Site + cron
# ----------------------------------------------------------------------------
# App URL — used for canonical URLs / OG absolute paths. Falls back to
# https://backrow.tv when unset (see src/lib/seo/absolute-url.ts).
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=your_cron_secret_here                # openssl rand -hex 32

# ----------------------------------------------------------------------------
# Sentry (optional, error monitoring)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ----------------------------------------------------------------------------
# Web Push (VAPID)
# ----------------------------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# ----------------------------------------------------------------------------
# Upstash Redis (distributed rate limiting — provisioned via Vercel Marketplace)
# ----------------------------------------------------------------------------
# The Vercel "Upstash for Redis" integration auto-populates these:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional — only populate if you're pointing at a direct Upstash account instead
# of the Vercel-provisioned resource.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Vercel BotID
# ----------------------------------------------------------------------------
# BotID has no env vars — configured in Vercel dashboard → Firewall → Deep Analysis.
# In dev (NODE_ENV !== "production") checkBotId() auto-bypasses; Playwright Just Works.

# ----------------------------------------------------------------------------
# Vercel Queues (@vercel/queue)
# ----------------------------------------------------------------------------
# Workers run via vercel.json experimentalTriggers; no app env vars are needed
# in production. For local dev, `vercel env pull` populates VERCEL_OIDC_TOKEN
# which the SDK uses to publish to the real queue service. Without it, the
# producer falls back to inline execution (see src/lib/jobs/enqueue.ts).
# VERCEL_OIDC_TOKEN=                               # populated by `vercel env pull`

# ----------------------------------------------------------------------------
# Dev-only toggles
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_ENABLE_TEST_AUTH=true
