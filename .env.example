# BackRow Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Development)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (for scripts - keep secret!)
# Get this from: https://supabase.com/dashboard/project/_/settings/api
# âš ï¸ WARNING: This key bypasses Row Level Security - never commit it!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# TMDB API Key (for movie search)
# Get one at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Resend (for transactional emails)
# Get one at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Site URL (for OAuth redirects, email links, invitation codes)
# Set to your production domain when deploying
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron Secret (for securing cron job endpoints)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Sentry (optional - for error monitoring)
# Get these from: https://sentry.io/settings/
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=your_sentry_project
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Test Auth Widget (development only)
# NEXT_PUBLIC_ENABLE_TEST_AUTH=true

# Web Push (VAPID) — for browser push notifications
# Generate a new keypair with: npx web-push generate-vapid-keys --json
# VAPID_SUBJECT must be a mailto: or https: URL (contact point shown to push services, never to users)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your@email.com