{
  "name": "backrow",
  "version": "0.1.0",
  "description": "A movie social platform where users create clubs, run themed movie festivals with friends, nominate films, and share critiques—casual or competitive.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/backrowtv/backrow.git"
  },
  "engines": {
    "node": ">=24.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:a11y": "eslint . --ext .ts,.tsx --max-warnings 0 2>&1 | grep jsx-a11y || echo 'No a11y warnings!'",
    "dev:email": "email dev --dir src/lib/email/templates/components --port 3001",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run src/__tests__/cache",
    "test:all": "vitest run",
    "test:integration": "vitest run src/__tests__/actions",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "delete-all-data": "tsx scripts/delete-all-data.ts",
    "create-test-user": "tsx scripts/create-test-user.ts",
    "delete-test-users": "tsx scripts/delete-test-users.ts",
    "generate-types": "supabase gen types typescript --project-id YOUR_PROJECT_ID > src/types/database.ts",
    "generate-types:help": "echo 'Replace YOUR_PROJECT_ID with your Supabase project ID. Get it from: https://supabase.com/dashboard/project/_/settings/general'",
    "test:rls": "bun run supabase/tests/run-rls-tests.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@leenguyen/react-flip-clock-countdown": "^1.7.2",
    "@number-flow/react": "^0.5.14",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@ridemountainpig/svgl-react": "^1.0.16",
    "@sentry/browser": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/canvas-confetti": "^1.9.0",
    "@types/papaparse": "^5.5.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/queue": "^0.1.6",
    "@vercel/speed-insights": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "next": "16.2.4",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-email": "^6.0.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^10.0.3",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@react-email/ui": "^6.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.12",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
